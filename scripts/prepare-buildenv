#!/bin/bash

set -e

SCRIPTS=$(dirname "$(realpath "$0")")
#shellcheck disable=SC1090
source "${SCRIPTS}/functions"

check_command_exists python git awk sed pip npm xargs grep

check_virtual_env

status "- Installing needed python modules (silent)"
grep -v django-cms docs/requirements.txt | grep -v '#' | xargs pip install --quiet django-admin &>/dev/null

check_command_exists django-admin

if [ ! -d cms ] ; then
    error "Please only run this command within the django CMS root folder"
    exit 1
fi

nvm_ver="$(cat .nvmrc)"

cd cms
status "- Installing node/npm"

load_nvm

nvm install "${nvm_ver}"
nvm use "${nvm_ver}"

status "- Installing required node packages (silent)"
npm install &>/dev/null

if ! command -v gulp; then
    npm install gulp@4.0.2 --loglevel warn
    check_command_exists gulp
fi

status "- Installing transifex cli and gettext"
# Install tx into $SCRIPTS (make-release invokes "$SCRIPTS/tx"). Do NOT silence
# this: the upstream installer's last step is `./tx -v`, so a failed download
# surfaces only as a bare exit 127 ("command not found") with no clue why.
( cd "$SCRIPTS" && curl -fsSL https://raw.githubusercontent.com/transifex/cli/master/install.sh | bash )
# Fail loudly here rather than much later at the first tx call.
[ -x "$SCRIPTS/tx" ] || { error "transifex cli (tx) was not installed to $SCRIPTS"; exit 1; }

# gettext provides msgfmt/msgmerge for compilemessages. apt-get needs sudo,
# unless the job already runs as root (e.g. in a container), where sudo may be
# absent and would itself fail with exit 127.
if command -v sudo >/dev/null; then
    sudo apt-get -qq install gettext
else
    apt-get -qq install gettext
fi

