#!/bin/bash

GREEN="\033[32;1m"
NORMAL="\033[0m"

# reverting files without modifications
ROOT=$(git rev-parse --show-toplevel)

for file in $(git status "${ROOT}/cms/locale" | grep modified | awk '{print $2}' ); do
    # Capture the significant diff lines in full rather than piping into
    # `grep -q`, which exits on the first match and sends SIGPIPE back up the
    # pipe ("grep: write error: Broken pipe"). Here both greps read to EOF.
    significant=$(git diff "${file}" | grep -v '^---\|^+++\|^.\"POT-Creation-Date:.*n\"\|[+-]\"PO-Revision-Date:.*n\"' | grep '^[-+]' || true)
    if [ -z "${significant}" ]; then
        echo -e " * ${GREEN}reverting${NORMAL} $file (no significant modifications)"
        git checkout "${file}"
    fi
done
