"            "

msgid ""
"\n"
"                    <p class=\"cms-welcome-notes\">You're seeing this message because you have\n"
"                        <code>DEBUG = True</code> in your django settings file and\n"
"                        haven't added any pages yet.\n"
"                    </p>\n"
"                "
msgstr ""
"\n"
